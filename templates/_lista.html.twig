{# Partial: tabela tajemnic dla jednej części różańca #}
<div class="table-responsive">
    <table class="table table-vcenter card-table">
        <thead>
            <tr>
                <th colspan="3" class="bg-primary-lt">
                    <strong>{{ czescNazwa }}</strong>
                </th>
            </tr>
            <tr>
                <th style="width: 50px">#</th>
                <th>Tajemnica</th>
                <th style="width: 300px">Osoba</th>
            </tr>
        </thead>
        <tbody>
            {% for tajemnica in tajemnice %}
                {% set isMine = app.user and tajemnica.user and tajemnica.user.id == app.user.id %}
                <tr{% if isMine %} class="bg-yellow-lt"{% endif %}>
                    <td class="text-secondary">{{ tajemnica.kolejnosc.numer }}.</td>
                    <td>{{ tajemnica.nazwa }}</td>
                    <td>
                        {% if tajemnica.user %}
                            <div class="d-flex align-items-center justify-content-between">
                                <span>
                                    <span class="avatar avatar-xs bg-primary-lt me-2">
                                        {{ tajemnica.user.userIdentifier|first|upper }}
                                    </span>
                                    {{ rozaniec_name(tajemnica.user) }}
                                </span>

                                {% if isMine %}
                                    <form method="post" action="{{ path('rozaniec_toggle', {id: tajemnica.id}) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('rozaniec_toggle_' ~ tajemnica.id) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-warning"
                                                onclick="return confirm('Czy na pewno chcesz zrezygnować z tej tajemnicy?')">
                                            Rezygnuję
                                        </button>
                                    </form>
                                {% endif %}

                                {% if is_granted('ROLE_ADMIN') and not isMine %}
                                    <button type="button" class="btn btn-sm btn-outline-secondary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#assignModal{{ tajemnica.id }}">
                                        Edycja
                                    </button>
                                {% endif %}
                            </div>
                        {% else %}
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="text-secondary">— wolne —</span>
                                <div>
                                    <form method="post" action="{{ path('rozaniec_toggle', {id: tajemnica.id}) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('rozaniec_toggle_' ~ tajemnica.id) }}">
                                        <button type="submit" class="btn btn-sm btn-primary">
                                            Modlę się!
                                        </button>
                                    </form>

                                    {% if is_granted('ROLE_ADMIN') %}
                                        <button type="button" class="btn btn-sm btn-outline-secondary ms-1"
                                                data-bs-toggle="modal"
                                                data-bs-target="#assignModal{{ tajemnica.id }}">
                                            Edycja
                                        </button>
                                    {% endif %}
                                </div>
                            </div>
                        {% endif %}
                    </td>
                </tr>

                {# Modal przypisania admina #}
                {% if is_granted('ROLE_ADMIN') %}
                <div class="modal modal-blur fade" id="assignModal{{ tajemnica.id }}" tabindex="-1">
                    <div class="modal-dialog modal-sm modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Przypisz osobę</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <form method="post" action="{{ path('rozaniec_assign', {id: tajemnica.id}) }}">
                                <div class="modal-body">
                                    <p class="text-secondary">{{ tajemnica.nazwa }}</p>
                                    <div class="mb-3">
                                        <label class="form-label">ID użytkownika</label>
                                        <input type="number" name="user_id" class="form-control"
                                               value="{{ tajemnica.user ? tajemnica.user.id : '' }}"
                                               placeholder="Zostaw puste aby odpiąć">
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn me-auto" data-bs-dismiss="modal">Anuluj</button>
                                    <button type="submit" class="btn btn-primary">Zapisz</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                {% endif %}
            {% endfor %}
        </tbody>
    </table>
</div>
